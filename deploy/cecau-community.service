[Unit]
Description=CECAU Community Website
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/community-website
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start -- --hostname 127.0.0.1 --port 3025
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
